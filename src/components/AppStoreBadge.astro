---
interface Props {
  href: string;
  label?: string;
}

const { href, label = 'Download on the App Store' } = Astro.props;
---

<a class="app-store-badge" href={href} target="_blank" rel="noopener" aria-label={label}>
  <img
    src="/badges/download-on-the-app-store.svg"
    alt={label}
    width="180"
    height="60"
    loading="lazy"
  />
</a>

<style>
  .app-store-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 60px;
    color: inherit;
    text-decoration: none;
    transition: transform var(--duration-normal) var(--ease-standard),
                filter var(--duration-normal) var(--ease-standard);
  }

  .app-store-badge:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 10px 24px color-mix(in srgb, var(--charcoal) 16%, transparent));
  }

  .app-store-badge:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 6px;
    border-radius: 12px;
  }

  .app-store-badge img {
    width: 180px;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .app-store-badge img {
      width: 168px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-store-badge {
      transition: none !important;
    }
  }
</style>
