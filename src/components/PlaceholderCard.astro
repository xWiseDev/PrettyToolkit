---
interface Props {
  index: number;
}

const { index } = Astro.props;

const gradients = [
  'linear-gradient(135deg, rgba(245, 220, 208, 0.5), rgba(238, 200, 196, 0.3))',
  'linear-gradient(135deg, rgba(232, 180, 184, 0.3), rgba(245, 220, 208, 0.4))',
  'linear-gradient(135deg, rgba(242, 208, 205, 0.4), rgba(232, 180, 184, 0.25))',
];

const gradient = gradients[index % gradients.length];
---

<div class="placeholder-card" style={`--card-gradient: ${gradient};`}>
  <div class="placeholder-shimmer"></div>
  <span class="coming-soon-pill">Coming Soon</span>
</div>

<style>
  .placeholder-card {
    position: relative;
    overflow: hidden;
    background: var(--card-gradient);
    backdrop-filter: blur(12px);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 24px;
    min-height: 280px;
  }

  .placeholder-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 30%,
      rgba(255, 255, 255, 0.25) 50%,
      transparent 70%
    );
    background-size: 250% 100%;
    animation: shimmer 4s var(--ease-standard) infinite;
  }

  .coming-soon-pill {
    position: relative;
    z-index: 1;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: 6px 16px;
    border-radius: 20px;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .placeholder-shimmer {
      animation: none !important;
      background: transparent;
    }
  }
</style>
