---
interface Props {
  size?: 'sm' | 'md';
}

const { size = 'md' } = Astro.props;
const iconSize = size === 'sm' ? 18 : 22;
---

<div class:list={['social-links', `social-${size}`]}>
  <a href="#" target="_blank" rel="noopener" aria-label="TikTok">
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor">
      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.78a8.18 8.18 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.21z"/>
    </svg>
  </a>
  <a href="#" target="_blank" rel="noopener" aria-label="Instagram">
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
      <circle cx="12" cy="12" r="5"/>
      <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
    </svg>
  </a>
  <a href="#" target="_blank" rel="noopener" aria-label="Pinterest">
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.15 9.42 7.6 11.19-.1-.94-.2-2.38.04-3.41.22-.93 1.4-5.93 1.4-5.93s-.36-.71-.36-1.77c0-1.66.96-2.9 2.16-2.9 1.02 0 1.51.76 1.51 1.68 0 1.02-.65 2.56-.99 3.98-.28 1.19.6 2.16 1.77 2.16 2.13 0 3.77-2.25 3.77-5.49 0-2.87-2.06-4.87-5.01-4.87-3.41 0-5.42 2.56-5.42 5.21 0 1.03.4 2.14.89 2.74.1.12.11.22.08.34-.09.38-.3 1.19-.34 1.36-.05.22-.18.27-.41.16-1.53-.71-2.48-2.95-2.48-4.75 0-3.87 2.81-7.42 8.11-7.42 4.26 0 7.57 3.03 7.57 7.09 0 4.23-2.67 7.63-6.37 7.63-1.24 0-2.41-.65-2.81-1.41l-.77 2.92c-.28 1.07-1.03 2.41-1.54 3.23C9.57 23.81 10.75 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/>
    </svg>
  </a>
  <a href="#" target="_blank" rel="noopener" aria-label="YouTube">
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor">
      <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 0 0 .5 6.19 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14A31.7 31.7 0 0 0 24 12a31.7 31.7 0 0 0-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
    </svg>
  </a>
  <a href="#" target="_blank" rel="noopener" aria-label="Reddit">
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm6.12 13.5c.04.24.06.49.06.74 0 3.77-4.39 6.83-9.81 6.83S-1.44 18.01-1.44 14.24c0-.25.02-.5.06-.74a1.78 1.78 0 0 1-.74-1.44c0-.98.8-1.78 1.78-1.78.47 0 .9.19 1.21.5 1.2-.86 2.85-1.42 4.68-1.49l.88-4.14a.3.3 0 0 1 .36-.24l2.93.62a1.26 1.26 0 0 1 2.39.39 1.26 1.26 0 0 1-1.26 1.26c-.64 0-1.17-.48-1.25-1.1l-2.6-.55-.79 3.7c1.8.08 3.42.64 4.6 1.49.31-.31.74-.5 1.21-.5.98 0 1.78.8 1.78 1.78 0 .57-.27 1.08-.7 1.41zM8.5 13.5a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5zm7 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5zm-6.77 3.82a.3.3 0 0 1 .42 0c.58.58 1.52.86 2.85.86s2.27-.28 2.85-.86a.3.3 0 0 1 .42.42c-.73.73-1.82 1.08-3.27 1.08s-2.54-.35-3.27-1.08a.3.3 0 0 1 0-.42z"/>
    </svg>
  </a>
</div>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .social-sm {
    gap: 12px;
  }

  .social-links a {
    color: var(--charcoal);
    opacity: 0.6;
    transition: color var(--duration-fast) var(--ease-standard),
                opacity var(--duration-fast) var(--ease-standard);
  }

  .social-links a:hover {
    color: var(--deep-rose);
    opacity: 1;
  }
</style>
