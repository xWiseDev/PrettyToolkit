---
import {
  defaultLocale,
  localeLabels,
  localeShortLabels,
  locales,
  localizedAlternates,
  localizedPath,
  type Locale,
  ui,
} from '../i18n';

interface Props {
  locale?: Locale;
  currentPath?: string;
  alternatePaths?: Record<Locale, string>;
}

const {
  locale = defaultLocale,
  currentPath = '/',
  alternatePaths = localizedAlternates(currentPath),
} = Astro.props;
const copy = ui[locale];
const languageLabel: Record<Locale, string> = {
  en: 'Language',
  fr: 'Langue',
  es: 'Idioma',
  de: 'Sprache',
};
---

<header class="site-header">
  <div class="header-inner">
    <a href={localizedPath(locale, '/')} class="brand-name">Pretty Toolkit</a>
    <nav class="desktop-nav">
      <a href={`${localizedPath(locale, '/')}#apps`}>{copy.nav.apps}</a>
      <a href="https://blog.prettytoolkit.com" target="_blank" rel="noopener">{copy.nav.blog}</a>
      <a href={localizedPath(locale, '/about')}>{copy.nav.about}</a>
      <a href={localizedPath(locale, '/support')}>{copy.nav.support}</a>
    </nav>
    <details class="language-menu">
      <summary aria-label={languageLabel[locale]}>
        <span class="language-globe" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20"></path>
            <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
            <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
          </svg>
        </span>
        <span>{localeShortLabels[locale]}</span>
        <svg class="language-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      </summary>
      <div class="language-panel" role="listbox" aria-label={languageLabel[locale]}>
        {locales.map((item) => (
          <a
            href={alternatePaths[item]}
            class:list={['language-option', item === locale && 'active']}
            aria-current={item === locale ? 'page' : undefined}
          >
            <span class="language-option-name">{localeLabels[item]}</span>
            <span class="language-option-code">{localeShortLabels[item]}</span>
          </a>
        ))}
      </div>
    </details>
    <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu-overlay" aria-hidden="true">
  <div class="mobile-menu-panel">
    <button class="mobile-menu-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <nav class="mobile-nav">
      <a href={`${localizedPath(locale, '/')}#apps`}>{copy.nav.apps}</a>
      <a href="https://blog.prettytoolkit.com" target="_blank" rel="noopener">{copy.nav.blog}</a>
      <a href={localizedPath(locale, '/about')}>{copy.nav.about}</a>
      <a href={localizedPath(locale, '/support')}>{copy.nav.support}</a>
      <div class="mobile-language-block">
        <p class="mobile-language-label">{languageLabel[locale]}</p>
        <div class="mobile-language-options" aria-label={languageLabel[locale]}>
          {locales.map((item) => (
            <a
              href={alternatePaths[item]}
              class:list={['mobile-language-option', item === locale && 'active']}
              aria-current={item === locale ? 'page' : undefined}
            >
              <span>{localeLabels[item]}</span>
              <span>{localeShortLabels[item]}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
  </div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 251, 248, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(232, 178, 174, 0.1);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .desktop-nav {
    display: flex;
    gap: 32px;
  }
  .desktop-nav a {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .desktop-nav a:hover {
    color: var(--text-accent);
  }
  .language-menu {
    position: relative;
  }
  .language-menu summary {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 11px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--off-white) 82%, var(--dusty-rose) 18%);
    box-shadow: var(--shadow-sm);
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: transform var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard),
                box-shadow var(--duration-fast) var(--ease-standard);
  }
  .language-menu summary::-webkit-details-marker {
    display: none;
  }
  .language-menu summary:hover,
  .language-menu[open] summary {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--off-white) 72%, var(--dusty-rose) 28%);
    box-shadow: var(--shadow-md);
  }
  .language-menu summary:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
  }
  .language-globe {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--warm-cream) 72%, var(--off-white) 28%);
    color: var(--text-accent);
  }
  .language-chevron {
    color: var(--text-secondary);
    transition: transform var(--duration-fast) var(--ease-standard);
  }
  .language-menu[open] .language-chevron {
    transform: rotate(180deg);
  }
  .language-panel {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 190px;
    padding: 8px;
    border-radius: 18px;
    background: color-mix(in srgb, var(--off-white) 88%, var(--section-warm) 12%);
    box-shadow: var(--shadow-lg);
    z-index: 200;
  }
  .language-panel::before {
    content: '';
    position: absolute;
    top: -6px;
    right: 22px;
    width: 12px;
    height: 12px;
    background: inherit;
    transform: rotate(45deg);
  }
  .language-option {
    position: relative;
    z-index: 1;
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 12px;
    color: var(--text-secondary);
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    transition: color var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard);
  }
  .language-option:hover,
  .language-option.active {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--dusty-rose) 13%, transparent);
  }
  .language-option-name {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .language-option-code {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--text-accent);
  }
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform var(--duration-fast) var(--ease-standard);
  }
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 150;
    overflow: hidden;
    background: rgba(44, 24, 16, 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-normal) var(--ease-standard),
                visibility var(--duration-normal) var(--ease-standard);
  }
  .mobile-menu-overlay.open {
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu-panel {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 280px;
    background: var(--off-white);
    padding: 24px;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-decelerate);
  }
  .mobile-menu-overlay.open .mobile-menu-panel {
    transform: translateX(0);
  }
  .mobile-menu-close {
    display: flex;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    margin-left: auto;
    padding: 4px;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 48px;
  }
  .mobile-nav a {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: var(--text-primary);
    text-decoration: none;
  }
  .mobile-language-block {
    margin-top: 12px;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--dusty-rose) 18%, transparent);
  }
  .mobile-language-label {
    margin: 0 0 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .mobile-language-options {
    display: grid;
    gap: 8px;
  }
  .mobile-nav .mobile-language-option {
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--section-warm) 70%, transparent);
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
    transition: color var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard);
  }
  .mobile-nav .mobile-language-option span:last-child {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--text-accent);
  }
  .mobile-nav .mobile-language-option:hover,
  .mobile-nav .mobile-language-option.active {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--dusty-rose) 14%, transparent);
  }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .language-menu { display: none; }
    .mobile-menu-toggle { display: flex; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-line,
    .mobile-menu-overlay,
    .mobile-menu-panel,
    .desktop-nav a,
    .language-menu summary,
    .language-chevron,
    .language-option,
    .mobile-language-option {
      transition: none !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const overlay = document.querySelector('.mobile-menu-overlay');
  const close = document.querySelector('.mobile-menu-close');
  const links = document.querySelectorAll('.mobile-nav a');
  const languageMenus = document.querySelectorAll('.language-menu');

  function openMenu() {
    overlay?.classList.add('open');
    overlay?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeMenu();
  });
  links.forEach((link) => link.addEventListener('click', closeMenu));

  document.addEventListener('click', (event) => {
    languageMenus.forEach((menu) => {
      if (!menu.contains(event.target)) {
        menu.removeAttribute('open');
      }
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      languageMenus.forEach((menu) => menu.removeAttribute('open'));
      closeMenu();
    }
  });
</script>
