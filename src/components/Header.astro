---
import {
  defaultLocale,
  localeLabels,
  localeShortLabels,
  locales,
  localizedAlternates,
  localizedPath,
  type Locale,
  ui,
} from '../i18n';

interface Props {
  locale?: Locale;
  currentPath?: string;
  alternatePaths?: Record<Locale, string>;
}

const {
  locale = defaultLocale,
  currentPath = '/',
  alternatePaths = localizedAlternates(currentPath),
} = Astro.props;
const copy = ui[locale];
const languageLabel: Record<Locale, string> = {
  en: 'Language',
  fr: 'Langue',
  es: 'Idioma',
  de: 'Sprache',
};
---

<header class="site-header">
  <div class="header-inner">
    <a href={localizedPath(locale, '/')} class="brand-name">Pretty Toolkit</a>
    <nav class="desktop-nav">
      <a href={`${localizedPath(locale, '/')}#apps`}>{copy.nav.apps}</a>
      <a href="https://blog.prettytoolkit.com" target="_blank" rel="noopener">{copy.nav.blog}</a>
      <a href={localizedPath(locale, '/about')}>{copy.nav.about}</a>
      <a href={localizedPath(locale, '/support')}>{copy.nav.support}</a>
    </nav>
    <div class="header-actions">
      <button class="language-dialog-toggle" aria-label={languageLabel[locale]} type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
          <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
        </svg>
        <span>{localeShortLabels[locale]}</span>
      </button>
      <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<dialog class="language-dialog" aria-labelledby="language-dialog-title">
  <div class="language-dialog-inner">
    <button class="language-dialog-close" aria-label="Close language menu" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <p class="language-dialog-kicker">{languageLabel[locale]}</p>
    <h2 id="language-dialog-title">Pretty Toolkit</h2>
    <div class="language-dialog-options">
      {locales.map((item) => (
        <a
          href={alternatePaths[item]}
          class:list={['language-dialog-option', item === locale && 'active']}
          aria-current={item === locale ? 'page' : undefined}
        >
          <span>{localeLabels[item]}</span>
          <span>{localeShortLabels[item]}</span>
        </a>
      ))}
    </div>
  </div>
</dialog>

<!-- Mobile menu overlay -->
<div class="mobile-menu-overlay" aria-hidden="true">
  <div class="mobile-menu-panel">
    <button class="mobile-menu-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <nav class="mobile-nav">
      <a href={`${localizedPath(locale, '/')}#apps`}>{copy.nav.apps}</a>
      <a href="https://blog.prettytoolkit.com" target="_blank" rel="noopener">{copy.nav.blog}</a>
      <a href={localizedPath(locale, '/about')}>{copy.nav.about}</a>
      <a href={localizedPath(locale, '/support')}>{copy.nav.support}</a>
    </nav>
  </div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 251, 248, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(232, 178, 174, 0.1);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .desktop-nav {
    display: flex;
    gap: 32px;
  }
  .desktop-nav a {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .desktop-nav a:hover {
    color: var(--text-accent);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .language-dialog-toggle {
    min-width: 44px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 13px;
    border: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--dusty-rose) 10%, transparent);
    color: var(--text-secondary);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    transition: color var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard),
                transform var(--duration-fast) var(--ease-standard);
  }
  .language-dialog-toggle:hover {
    color: var(--text-accent);
    background: color-mix(in srgb, var(--dusty-rose) 16%, transparent);
    transform: translateY(-1px);
  }
  .language-dialog-toggle:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
  }
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform var(--duration-fast) var(--ease-standard);
  }
  .language-dialog {
    width: min(360px, calc(100vw - 40px));
    padding: 0;
    border: none;
    border-radius: 22px;
    background: var(--off-white);
    box-shadow: var(--shadow-lg);
    color: var(--text-primary);
  }
  .language-dialog::backdrop {
    background: color-mix(in srgb, var(--charcoal) 32%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .language-dialog-inner {
    position: relative;
    padding: 28px;
  }
  .language-dialog-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--dusty-rose) 10%, transparent);
    color: var(--text-primary);
    cursor: pointer;
  }
  .language-dialog-kicker {
    margin: 0 44px 6px 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .language-dialog h2 {
    margin: 0 44px 22px 0;
    font-size: 1.55rem;
  }
  .language-dialog-options {
    display: grid;
    gap: 8px;
  }
  .language-dialog-option {
    min-height: 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 14px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--section-warm) 62%, transparent);
    color: var(--text-secondary);
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard),
                background var(--duration-fast) var(--ease-standard),
                transform var(--duration-fast) var(--ease-standard);
  }
  .language-dialog-option span:last-child {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--text-accent);
  }
  .language-dialog-option:hover,
  .language-dialog-option.active {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--dusty-rose) 15%, transparent);
    transform: translateY(-1px);
  }
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 150;
    overflow: hidden;
    background: rgba(44, 24, 16, 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-normal) var(--ease-standard),
                visibility var(--duration-normal) var(--ease-standard);
  }
  .mobile-menu-overlay.open {
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu-panel {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 280px;
    background: var(--off-white);
    padding: 24px;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-decelerate);
  }
  .mobile-menu-overlay.open .mobile-menu-panel {
    transform: translateX(0);
  }
  .mobile-menu-close {
    display: flex;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    margin-left: auto;
    padding: 4px;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 48px;
  }
  .mobile-nav a {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: var(--text-primary);
    text-decoration: none;
  }
  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .language-dialog-toggle {
      width: 42px;
      height: 42px;
      padding: 0;
    }
    .language-dialog-toggle span {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }
    .mobile-menu-toggle { display: flex; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-line,
    .language-dialog-toggle,
    .language-dialog-option,
    .mobile-menu-overlay,
    .mobile-menu-panel,
    .desktop-nav a {
      transition: none !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const overlay = document.querySelector('.mobile-menu-overlay');
  const close = document.querySelector('.mobile-menu-close');
  const links = document.querySelectorAll('.mobile-nav a');
  const languageToggle = document.querySelector('.language-dialog-toggle');
  const languageDialog = document.querySelector('.language-dialog');
  const languageClose = document.querySelector('.language-dialog-close');

  function openMenu() {
    overlay?.classList.add('open');
    overlay?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeMenu();
  });
  links.forEach((link) => link.addEventListener('click', closeMenu));
  languageToggle?.addEventListener('click', () => {
    closeMenu();
    languageDialog?.showModal();
  });
  languageClose?.addEventListener('click', () => {
    languageDialog?.close();
  });
  languageDialog?.addEventListener('click', (event) => {
    if (event.target === languageDialog) {
      languageDialog.close();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });
</script>
