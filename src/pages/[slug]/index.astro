---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import PlaceholderCard from '../../components/PlaceholderCard.astro';
import { apps, categories } from '../../data/apps';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
};

const { app } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://prettytoolkit.com';
const pageUrl = new URL(`/${app.slug}/`, siteUrl).toString();
const privacyUrl = app.privacy ? new URL(`/${app.slug}/privacy/`, siteUrl).toString() : undefined;
const appIconUrl = new URL(app.icon, siteUrl).toString();
const firstFaq = app.faqs?.[0];
const privacyFaq =
  app.faqs?.find((faq) => /private|privacy|safe/i.test(faq.question)) ||
  app.faqs?.find((faq) => /offline/i.test(faq.question));
const appKeywords = [
  app.name,
  app.tagline,
  categories[app.category],
  `${categories[app.category]} app for iPhone`,
  ...app.features.map((feature) => feature.title),
];
const crossPromoApps = apps
  .filter((candidate) => candidate.slug !== app.slug)
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);
const placeholderCount = Math.max(0, 3 - crossPromoApps.length);

const softwareApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": app.name,
  "description": app.description,
  "applicationCategory": "UtilitiesApplication",
  "applicationSubCategory": categories[app.category],
  "operatingSystem": "iOS",
  "url": pageUrl,
  "image": appIconUrl,
  "publisher": {
    "@type": "Organization",
    "name": "Pretty Toolkit",
    "url": siteUrl,
  },
  "keywords": appKeywords.join(", "),
  "featureList": app.features.map((feature) => feature.title),
  "isAccessibleForFree": app.status === "live",
  ...(privacyUrl ? { "privacyPolicy": privacyUrl } : {}),
  ...(app.status === "live" && app.appStoreUrl ? {
    "downloadUrl": app.appStoreUrl,
    "installUrl": app.appStoreUrl,
    "sameAs": [app.appStoreUrl],
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
    },
  } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Pretty Toolkit",
      "item": `${siteUrl}/`,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": app.name,
      "item": pageUrl,
    },
  ],
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${app.name} — ${app.tagline}`,
  "description": app.description,
  "url": pageUrl,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Pretty Toolkit",
    "url": siteUrl,
  },
  "about": {
    "@type": "SoftwareApplication",
    "name": app.name,
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "iOS",
  },
};

const featureIcons: Record<string, string> = {
  scan: '<circle cx="12" cy="12" r="3"/><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/>',
  barcode: '<path d="M3 5v14"/><path d="M8 5v14"/><path d="M12 5v14"/><path d="M17 5v14"/><path d="M21 5v14"/>',
  history: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'qr-create': '<rect x="2" y="2" width="8" height="8" rx="1"/><rect x="14" y="2" width="8" height="8" rx="1"/><rect x="2" y="14" width="8" height="8" rx="1"/><rect x="14" y="14" width="4" height="4" rx="0.5"/><path d="M22 14h-4v4"/><path d="M22 22h-4v-4"/>',
  share: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>',
  palette: '<circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.75 1.5-1.5 0-.39-.15-.74-.4-1.02a1.5 1.5 0 0 1 1.12-2.48H16c3.31 0 6-2.69 6-6 0-4.96-4.5-9-10-9z"/>',
};
---

<BaseLayout
  title={`${app.name} — ${app.tagline} | Pretty Toolkit`}
  description={app.description}
>
  <!-- ===== APP HERO ===== -->
  <section
    class="app-hero grain-overlay"
    style={`--app-accent: ${app.accentColor};`}
  >
    <div class="app-hero-content section-choreography visible">
      <div class="app-hero-icon choreo-headline">
        <img
          class="app-hero-icon-img"
          src={app.icon}
          alt={`${app.name} app icon`}
          width="140"
          height="140"
        />
      </div>
      <h1 class="app-hero-name choreo-subtitle">{app.name}</h1>
      <p class="app-hero-tagline choreo-content">{app.description}</p>
      <div class="app-hero-cta choreo-cta">
        {app.status === "live" && app.appStoreUrl ? (
          <a href={app.appStoreUrl} class="btn-primary" target="_blank" rel="noopener">
            Download on the App Store
          </a>
        ) : (
          <span class="coming-soon-hero-badge">Coming Soon to the App Store</span>
        )}
      </div>
    </div>
  </section>

  {firstFaq && (
    <section class="answer-section">
      <div class="answer-inner reveal section-choreography">
        <p class="answer-label choreo-headline">{categories[app.category]} app for iPhone</p>
        <h2 class="answer-heading choreo-subtitle">{firstFaq.question}</h2>
        <p class="answer-copy choreo-content">{firstFaq.answer}</p>
      </div>
    </section>
  )}

  <section class="capabilities-section">
    <div class="capabilities-inner reveal section-choreography">
      <p class="capabilities-label choreo-headline">{app.name} features</p>
      <h2 class="capabilities-heading choreo-subtitle">What can you do with {app.name}?</h2>
      <p class="capabilities-intro choreo-content">
        {app.name} is built for quick, focused utility on iPhone. These are the core things it helps you do, without clutter or extra setup.
      </p>
      <div class="capability-list choreo-meta">
        {app.features.slice(0, 4).map((feature) => (
          <article class="capability-item">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
      {privacyFaq && (
        <div class="privacy-answer choreo-cta-text">
          <h3>{privacyFaq.question}</h3>
          <p>{privacyFaq.answer}</p>
        </div>
      )}
    </div>
  </section>

  <!-- ===== FEATURE SHOWCASE ===== -->
  {app.features.map((feature, i) => (
    <section class={`feature-section ${i % 2 === 0 ? 'bg-warm' : 'bg-off-white'}`}>
      <div class="feature-row reveal section-choreography" data-reversed={i % 2 !== 0 ? "true" : undefined}>
        <div class="feature-text">
          <div class="feature-icon-wrap choreo-headline" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={featureIcons[feature.icon] || featureIcons.scan} />
          </div>
          <h3 class="feature-title choreo-subtitle">{feature.title}</h3>
          <p class="feature-desc choreo-content">{feature.description}</p>
        </div>
        <div class="feature-visual choreo-meta">
          <div
            class="feature-placeholder"
            style={`background: linear-gradient(135deg, ${app.accentColor}18, ${app.accentColor}35);`}
          />
        </div>
      </div>
    </section>
  ))}

  <!-- ===== SCREENSHOT GALLERY ===== -->
  <section class="gallery-section">
    <div class="gallery-container reveal">
      <h2 class="gallery-heading reveal-headline">See it in action.</h2>
      {app.screenshots.length > 0 ? (
        <div class="gallery-grid">
          {app.screenshots.slice(0, 5).map((src, i) => (
            <div class="gallery-device">
              <img src={src} alt={`${app.name} screenshot ${i + 1}`} loading="lazy" />
            </div>
          ))}
        </div>
      ) : (
        <div class="gallery-grid">
          {[0, 1, 2].map((i) => (
            <div
              class="gallery-placeholder"
              style={`background: linear-gradient(135deg, ${app.accentColor}15, ${app.accentColor}30);`}
            >
              <span>{app.name}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  {app.faqs && app.faqs.length > 0 && (
    <section class="faq-section">
      <div class="faq-inner reveal section-choreography">
        <h2 class="faq-heading choreo-headline">Questions? Answers.</h2>
        <div class="choreo-content">
          <FaqAccordion faqs={app.faqs} />
        </div>
      </div>
    </section>
  )}

  <!-- ===== DOWNLOAD CTA ===== -->
  <section class="download-cta reveal section-choreography">
    <div class="download-icon choreo-headline">
      <img
        class="cta-icon-img"
        src={app.icon}
        alt={`${app.name} app icon`}
        width="72"
        height="72"
        loading="lazy"
      />
    </div>
    <h2 class="download-heading choreo-subtitle">Ready to try {app.name}?</h2>
    <div class="choreo-cta">
      {app.status === "live" && app.appStoreUrl ? (
        <a href={app.appStoreUrl} class="btn-primary" target="_blank" rel="noopener">
          Download on the App Store
        </a>
      ) : (
        <span class="coming-soon-hero-badge">Coming Soon to the App Store</span>
      )}
    </div>
  </section>

  <!-- ===== CROSS PROMO ===== -->
  <section class="cross-promo-section">
    <div class="cross-promo-inner reveal section-choreography">
      <h2 class="cross-promo-heading choreo-headline">More from Pretty Toolkit</h2>
      <p class="cross-promo-subtitle choreo-subtitle">More apps are on the way.</p>
      <div class="cross-promo-grid choreo-content">
        {crossPromoApps.map((crossPromoApp) => (
          <AppCard app={crossPromoApp} />
        ))}
        {Array.from({ length: placeholderCount }).map((_, i) => (
          <PlaceholderCard index={i} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== APP HERO ===== */
  .app-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 24px;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        ellipse 70% 40% at 50% 20%,
        color-mix(in srgb, var(--app-accent) 12%, transparent) 0%,
        color-mix(in srgb, var(--app-accent) 4%, transparent) 60%,
        transparent 100%
      );
  }
  .app-hero-content {
    max-width: 600px;
  }
  .app-hero-icon {
    margin-bottom: 32px;
  }
  .app-hero-icon-img {
    width: 140px;
    height: 140px;
    border-radius: 32px;
    margin: 0 auto;
    display: block;
    box-shadow: var(--shadow-lg);
  }
  .app-hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 12px;
  }
  .app-hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    margin-bottom: 40px;
    line-height: 1.7;
  }
  .coming-soon-hero-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--section-warm);
    padding: 12px 28px;
    border-radius: 12px;
    display: inline-block;
  }

  /* ===== DIRECT ANSWER ===== */
  .answer-section {
    padding: 100px 24px;
    background: var(--section-warm);
  }
  .answer-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .answer-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-accent);
    margin-bottom: 14px;
  }
  .answer-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 18px;
  }
  .answer-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }

  /* ===== CAPABILITIES ===== */
  .capabilities-section {
    padding: 110px 24px;
    background: var(--off-white);
  }
  .capabilities-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .capabilities-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-accent);
    text-align: center;
    margin-bottom: 14px;
  }
  .capabilities-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 18px;
  }
  .capabilities-intro {
    max-width: 680px;
    margin: 0 auto 44px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.8;
    text-align: center;
  }
  .capability-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  .capability-item {
    background: var(--card-bg);
    border-radius: 18px;
    padding: 24px;
    box-shadow: var(--shadow-sm);
  }
  .capability-item h3,
  .privacy-answer h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
  }
  .capability-item p,
  .privacy-answer p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .privacy-answer {
    max-width: 760px;
    margin: 28px auto 0;
    background: color-mix(in srgb, var(--dusty-rose) 9%, transparent);
    border-radius: 18px;
    padding: 24px 28px;
  }

  /* ===== FEATURE SECTIONS ===== */
  .feature-section {
    padding: 100px 24px;
  }
  .bg-warm {
    background: var(--section-warm);
  }
  .bg-off-white {
    background: var(--off-white);
  }
  .feature-row {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .feature-row[data-reversed="true"] .feature-text {
    order: 2;
  }
  .feature-row[data-reversed="true"] .feature-visual {
    order: 1;
  }
  .feature-icon-wrap {
    color: var(--dusty-rose);
    margin-bottom: 16px;
  }
  .feature-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .feature-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .feature-visual {
    display: flex;
    justify-content: center;
  }
  .feature-placeholder {
    width: 100%;
    aspect-ratio: 9 / 16;
    max-width: 240px;
    border-radius: 24px;
    box-shadow: var(--shadow-md);
  }

  /* ===== GALLERY ===== */
  .gallery-section {
    padding: 120px 24px;
    background: var(--section-warm);
    overflow: hidden;
  }
  .gallery-container {
    max-width: 900px;
    margin: 0 auto;
  }
  .gallery-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 64px;
  }
  .gallery-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
  }
  .gallery-placeholder {
    width: 200px;
    height: 400px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
  }
  .gallery-placeholder span {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  .gallery-device img {
    width: 200px;
    height: auto;
    border-radius: 24px;
    box-shadow: var(--shadow-md);
  }

  /* ===== FAQ ===== */
  .faq-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .faq-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .faq-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
  }

  /* ===== DOWNLOAD CTA ===== */
  .download-cta {
    text-align: center;
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .download-icon {
    margin-bottom: 24px;
  }
  .cta-icon-img {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    margin: 0 auto;
    display: block;
    box-shadow: var(--shadow-md);
  }
  .download-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 32px;
  }

  /* ===== CROSS PROMO ===== */
  .cross-promo-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .cross-promo-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }
  .cross-promo-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .cross-promo-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    margin-bottom: 48px;
  }
  .cross-promo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .feature-section { padding: 80px 24px; }
    .feature-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .feature-row[data-reversed="true"] .feature-text,
    .feature-row[data-reversed="true"] .feature-visual {
      order: unset;
    }
    .feature-placeholder {
      max-width: 180px;
    }
    .gallery-section { padding: 80px 24px; }
    .gallery-grid {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      justify-content: flex-start;
      padding: 0 16px;
    }
    .gallery-placeholder,
    .gallery-device {
      scroll-snap-align: center;
      flex: 0 0 180px;
    }
    .gallery-placeholder {
      width: 180px;
      height: 360px;
    }
    .answer-section { padding: 80px 24px; }
    .capabilities-section { padding: 80px 24px; }
    .capability-list {
      grid-template-columns: 1fr;
    }
    .faq-section { padding: 80px 24px; }
    .download-cta { padding: 80px 24px; }
    .cross-promo-section { padding: 80px 24px; }
    .cross-promo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

{app.faqs && app.faqs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": app.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />
)}
