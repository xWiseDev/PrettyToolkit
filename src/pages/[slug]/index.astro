---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';
import AppStoreBadge from '../../components/AppStoreBadge.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import PlaceholderCard from '../../components/PlaceholderCard.astro';
import { apps } from '../../data/apps';
import {
  categoryLabels,
  defaultLocale,
  getLocalizedApp,
  getLocalizedApps,
  localizedAlternates,
  localizedAppPath,
  localizedPrivacyPath,
  type Locale,
  ui,
} from '../../i18n';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
};

const { app } = Astro.props;
const locale = (Astro.props.locale ?? defaultLocale) as Locale;
const localizedApp = getLocalizedApp(app, locale);
const localizedApps = getLocalizedApps(locale);
const copy = ui[locale];
const categoryName = categoryLabels[locale][localizedApp.category];
const canonicalPath = localizedAppPath(locale, localizedApp.slug);
const alternatePaths = localizedAlternates(`/${localizedApp.slug}`);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://prettytoolkit.com';
const pageUrl = new URL(canonicalPath, siteUrl).toString();
const privacyUrl = localizedApp.privacy ? new URL(localizedPrivacyPath(locale, localizedApp.slug), siteUrl).toString() : undefined;
const appIconUrl = new URL(localizedApp.icon, siteUrl).toString();
const firstFaq = localizedApp.faqs?.[0];
const privacyFaq =
  localizedApp.faqs?.find((faq) => /private|privacy|safe|prive|privacidad|privat|datenschutz/i.test(faq.question)) ||
  localizedApp.faqs?.find((faq) => /offline|hors ligne|sin internet/i.test(faq.question));
const appKeywords = [
  localizedApp.name,
  localizedApp.tagline,
  categoryName,
  `${categoryName} ${copy.appPage.categorySuffix}`,
  ...localizedApp.features.map((feature) => feature.title),
];
const crossPromoApps = localizedApps
  .filter((candidate) => candidate.slug !== localizedApp.slug)
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);
const placeholderCount = Math.max(0, 3 - crossPromoApps.length);
const heroScreenshots = localizedApp.screenshots.slice(0, 2);

const softwareApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": localizedApp.name,
  "description": localizedApp.description,
  "applicationCategory": "UtilitiesApplication",
  "applicationSubCategory": categoryName,
  "operatingSystem": "iOS",
  "url": pageUrl,
  "image": appIconUrl,
  "publisher": {
    "@type": "Organization",
    "name": "Pretty Toolkit",
    "url": siteUrl,
  },
  "keywords": appKeywords.join(", "),
  "featureList": localizedApp.features.map((feature) => feature.title),
  "isAccessibleForFree": localizedApp.status === "live",
  "inLanguage": locale,
  ...(privacyUrl ? { "privacyPolicy": privacyUrl } : {}),
  ...(localizedApp.status === "live" && localizedApp.appStoreUrl ? {
    "downloadUrl": localizedApp.appStoreUrl,
    "installUrl": localizedApp.appStoreUrl,
    "sameAs": [localizedApp.appStoreUrl],
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
    },
  } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Pretty Toolkit",
      "item": new URL(locale === 'en' ? '/' : `/${locale}/`, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": localizedApp.name,
      "item": pageUrl,
    },
  ],
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${localizedApp.name} — ${localizedApp.tagline}`,
  "description": localizedApp.description,
  "url": pageUrl,
  "inLanguage": locale,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Pretty Toolkit",
    "url": siteUrl,
  },
  "about": {
    "@type": "SoftwareApplication",
    "name": localizedApp.name,
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "iOS",
  },
};

---

<BaseLayout
  title={`${localizedApp.name} — ${localizedApp.tagline} | Pretty Toolkit`}
  description={localizedApp.description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
>
  <!-- ===== APP HERO ===== -->
  <section
    class="app-hero grain-overlay"
    style={`--app-accent: ${localizedApp.accentColor};`}
  >
    <div class="app-hero-inner section-choreography visible">
      <div class="app-hero-content">
        <div class="app-hero-icon choreo-headline">
          <img
            class="app-hero-icon-img"
            src={localizedApp.icon}
            alt={copy.appPage.appIconAlt(localizedApp.name)}
            width="140"
            height="140"
          />
        </div>
        <h1 class="app-hero-name choreo-subtitle">{localizedApp.name}</h1>
        <p class="app-hero-tagline choreo-content">{localizedApp.description}</p>
        <div class="app-hero-cta choreo-cta">
          {localizedApp.status === "live" && localizedApp.appStoreUrl ? (
            <AppStoreBadge href={localizedApp.appStoreUrl} />
          ) : (
            <span class="coming-soon-hero-badge">{copy.appPage.comingSoon}</span>
          )}
        </div>
        <p class="app-trust-row choreo-cta-text" aria-label={`${localizedApp.name} trust signals`}>
          {copy.brand.trust.map((item) => <span>{item}</span>)}
        </p>
      </div>

      {heroScreenshots.length > 0 && (
        <div class="app-hero-preview choreo-content" aria-hidden="true">
          {heroScreenshots.map((src, i) => (
            <div class:list={['hero-device', i === 0 ? 'hero-device-primary' : 'hero-device-secondary']}>
              <picture>
                <source srcset={src.replace(/\.(png|jpe?g)$/i, '.webp')} type="image/webp" />
                <img src={src} alt="" width="240" height="480" loading={i === 0 ? 'eager' : 'lazy'} />
              </picture>
            </div>
          ))}
        </div>
        )}
      </div>
  </section>

  {firstFaq && (
    <section class="answer-section">
      <div class="answer-inner reveal section-choreography">
        <p class="answer-label choreo-headline">{categoryName} {copy.appPage.categorySuffix}</p>
        <h2 class="answer-heading choreo-subtitle">{firstFaq.question}</h2>
        <p class="answer-copy choreo-content">{firstFaq.answer}</p>
      </div>
    </section>
  )}

  <section class="capabilities-section">
    <div class="capabilities-inner reveal section-choreography">
      <p class="capabilities-label choreo-headline">{copy.appPage.featuresLabel(localizedApp.name)}</p>
      <h2 class="capabilities-heading choreo-subtitle">{copy.appPage.capabilitiesHeading(localizedApp.name)}</h2>
      <p class="capabilities-intro choreo-content">
        {copy.appPage.capabilitiesIntro(localizedApp.name)}
      </p>
      <div class="capability-list choreo-meta">
        {localizedApp.features.slice(0, 4).map((feature) => (
          <article class="capability-item">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
      {privacyFaq && (
        <div class="privacy-answer choreo-cta-text">
          <h3>{privacyFaq.question}</h3>
          <p>{privacyFaq.answer}</p>
        </div>
      )}
    </div>
  </section>

  <!-- ===== SCREENSHOT GALLERY ===== -->
  <section class="gallery-section">
    <div class="gallery-container reveal">
      <h2 class="gallery-heading reveal-headline">{copy.appPage.gallery}</h2>
      {localizedApp.screenshots.length > 0 ? (
        <div class="gallery-grid gallery-grid-screenshots">
          {localizedApp.screenshots.slice(0, 5).map((src, i) => (
            <div class="gallery-device">
              <picture>
                <source srcset={src.replace(/\.(png|jpe?g)$/i, '.webp')} type="image/webp" />
                <img src={src} alt={copy.appPage.screenshotAlt(localizedApp.name, i + 1)} loading="lazy" />
              </picture>
            </div>
          ))}
        </div>
      ) : (
        <div class="gallery-grid gallery-grid-placeholders">
          {[0, 1, 2].map((i) => (
            <div
              class="gallery-placeholder"
              style={`background: linear-gradient(135deg, ${localizedApp.accentColor}15, ${localizedApp.accentColor}30);`}
            >
              <span>{localizedApp.name}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  {localizedApp.faqs && localizedApp.faqs.length > 0 && (
    <section class="faq-section">
      <div class="faq-inner reveal section-choreography">
        <h2 class="faq-heading choreo-headline">{copy.appPage.faq}</h2>
        <div class="choreo-content">
          <FaqAccordion faqs={localizedApp.faqs} />
        </div>
      </div>
    </section>
  )}

  <!-- ===== DOWNLOAD CTA ===== -->
  <section class="download-cta reveal section-choreography">
    <div class="download-icon choreo-headline">
      <img
        class="cta-icon-img"
        src={localizedApp.icon}
        alt={copy.appPage.appIconAlt(localizedApp.name)}
        width="72"
        height="72"
        loading="lazy"
      />
    </div>
    <h2 class="download-heading choreo-subtitle">{copy.appPage.downloadHeading(localizedApp.name)}</h2>
    <div class="choreo-cta">
      {localizedApp.status === "live" && localizedApp.appStoreUrl ? (
        <AppStoreBadge href={localizedApp.appStoreUrl} />
      ) : (
        <span class="coming-soon-hero-badge">{copy.appPage.comingSoon}</span>
      )}
    </div>
  </section>

  <!-- ===== CROSS PROMO ===== -->
  <section class="cross-promo-section">
    <div class="cross-promo-inner reveal section-choreography">
      <h2 class="cross-promo-heading choreo-headline">{copy.appPage.crossPromoHeading}</h2>
      <p class="cross-promo-subtitle choreo-subtitle">{copy.appPage.crossPromoSubtitle}</p>
      <div class="cross-promo-grid choreo-content">
        {crossPromoApps.map((crossPromoApp) => (
          <AppCard app={crossPromoApp} locale={locale} />
        ))}
        {Array.from({ length: placeholderCount }).map((_, i) => (
          <PlaceholderCard index={i} locale={locale} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== APP HERO ===== */
  .app-hero {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 96px 24px 88px;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        ellipse 70% 40% at 50% 20%,
        color-mix(in srgb, var(--app-accent) 12%, transparent) 0%,
        color-mix(in srgb, var(--app-accent) 4%, transparent) 60%,
        transparent 100%
      );
  }
  .app-hero-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.85fr);
    align-items: center;
    gap: 72px;
  }
  .app-hero-content {
    max-width: 600px;
    text-align: left;
  }
  .app-hero-icon {
    margin-bottom: 28px;
  }
  .app-hero-icon-img {
    width: 140px;
    height: 140px;
    border-radius: 32px;
    margin: 0;
    display: block;
    box-shadow: var(--shadow-lg);
  }
  .app-hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 12px;
  }
  .app-hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .app-hero-cta {
    display: flex;
    align-items: center;
  }
  .app-trust-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin: 16px 0 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .app-trust-row span {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .app-trust-row span:not(:last-child)::after {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--text-accent);
    opacity: 0.55;
  }
  .app-hero-preview {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }
  .app-hero-preview::before {
    content: '';
    position: absolute;
    inset: 70px 16px 56px;
    z-index: -1;
    border-radius: 40px;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--app-accent) 16%, transparent),
        color-mix(in srgb, var(--warm-cream) 36%, transparent)
      );
    box-shadow: var(--shadow-sm);
  }
  .hero-device {
    position: relative;
    flex: 0 0 clamp(190px, 20vw, 250px);
    padding: 8px;
    border-radius: 30px;
    background: color-mix(in srgb, var(--card-bg) 82%, var(--section-warm));
    box-shadow: var(--shadow-lg);
  }
  .hero-device picture,
  .hero-device img {
    display: block;
  }
  .hero-device img {
    width: 100%;
    height: auto;
    border-radius: 24px;
  }
  .hero-device-primary {
    z-index: 2;
    transform: translateX(26px) rotate(-2deg);
  }
  .hero-device-secondary {
    z-index: 1;
    transform: translateX(-26px) translateY(34px) rotate(3deg) scale(0.92);
  }
  .coming-soon-hero-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--section-warm);
    padding: 12px 28px;
    border-radius: 12px;
    display: inline-block;
  }

  /* ===== DIRECT ANSWER ===== */
  .answer-section {
    padding: 100px 24px;
    background: var(--section-warm);
  }
  .answer-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .answer-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-accent);
    margin-bottom: 14px;
  }
  .answer-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 18px;
  }
  .answer-copy {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }

  /* ===== CAPABILITIES ===== */
  .capabilities-section {
    padding: 110px 24px;
    background: var(--off-white);
  }
  .capabilities-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .capabilities-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-accent);
    text-align: center;
    margin-bottom: 14px;
  }
  .capabilities-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 18px;
  }
  .capabilities-intro {
    max-width: 680px;
    margin: 0 auto 44px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.8;
    text-align: center;
  }
  .capability-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  .capability-item {
    background: var(--card-bg);
    border-radius: 18px;
    padding: 24px;
    box-shadow: var(--shadow-sm);
  }
  .capability-item h3,
  .privacy-answer h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
  }
  .capability-item p,
  .privacy-answer p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .privacy-answer {
    max-width: 760px;
    margin: 28px auto 0;
    background: color-mix(in srgb, var(--dusty-rose) 9%, transparent);
    border-radius: 18px;
    padding: 24px 28px;
  }

  /* ===== GALLERY ===== */
  .gallery-section {
    padding: 120px 24px;
    background: var(--section-warm);
    overflow: hidden;
  }
  .gallery-container {
    max-width: 1120px;
    margin: 0 auto;
  }
  .gallery-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 56px;
  }
  .gallery-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
  }
  .gallery-grid-screenshots {
    position: relative;
    gap: 0;
    min-height: 540px;
    padding: 34px 18px 42px;
    isolation: isolate;
  }
  .gallery-grid-screenshots::before {
    content: '';
    position: absolute;
    inset: 90px 0 40px;
    z-index: -1;
    border-radius: 36px;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--dusty-rose) 14%, transparent),
        color-mix(in srgb, var(--warm-cream) 34%, transparent)
      );
    box-shadow: var(--shadow-sm);
  }
  .gallery-placeholder {
    width: 200px;
    height: 400px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
  }
  .gallery-placeholder span {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  .gallery-device picture,
  .gallery-device img {
    display: block;
  }
  .gallery-grid-screenshots .gallery-device {
    position: relative;
    flex: 0 0 clamp(160px, 18vw, 220px);
    padding: 8px;
    border-radius: 30px;
    background: color-mix(in srgb, var(--card-bg) 82%, var(--section-warm));
    box-shadow: var(--shadow-lg);
    transition: transform var(--duration-normal) var(--ease-standard),
                box-shadow var(--duration-normal) var(--ease-standard);
  }
  .gallery-grid-screenshots .gallery-device:nth-child(1) {
    transform: translateX(36px) translateY(28px) rotate(-4deg);
    z-index: 1;
  }
  .gallery-grid-screenshots .gallery-device:nth-child(2) {
    transform: translateX(18px) translateY(4px) rotate(-2deg);
    z-index: 2;
  }
  .gallery-grid-screenshots .gallery-device:nth-child(3) {
    transform: translateY(-24px) scale(1.05);
    z-index: 5;
  }
  .gallery-grid-screenshots .gallery-device:nth-child(4) {
    transform: translateX(-18px) translateY(4px) rotate(2deg);
    z-index: 2;
  }
  .gallery-grid-screenshots .gallery-device:nth-child(5) {
    transform: translateX(-36px) translateY(28px) rotate(4deg);
    z-index: 1;
  }
  .gallery-grid-screenshots .gallery-device:hover {
    transform: translateY(-32px) scale(1.06);
    z-index: 8;
    box-shadow: var(--shadow-lg);
  }
  .gallery-device img {
    width: 100%;
    height: auto;
    border-radius: 24px;
  }
  .gallery-grid-placeholders .gallery-device img {
    width: 200px;
    box-shadow: var(--shadow-md);
  }

  /* ===== FAQ ===== */
  .faq-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .faq-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .faq-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
  }

  /* ===== DOWNLOAD CTA ===== */
  .download-cta {
    text-align: center;
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .download-icon {
    margin-bottom: 24px;
  }
  .cta-icon-img {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    margin: 0 auto;
    display: block;
    box-shadow: var(--shadow-md);
  }
  .download-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 32px;
  }

  /* ===== CROSS PROMO ===== */
  .cross-promo-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .cross-promo-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }
  .cross-promo-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .cross-promo-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    margin-bottom: 48px;
  }
  .cross-promo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .app-hero {
      min-height: auto;
      padding: 72px 24px 80px;
    }
    .app-hero-inner {
      grid-template-columns: 1fr;
      gap: 44px;
    }
    .app-hero-content {
      max-width: 620px;
      text-align: center;
    }
    .app-hero-icon-img {
      margin: 0 auto;
      width: 120px;
      height: 120px;
      border-radius: 28px;
    }
    .app-hero-cta,
    .app-trust-row {
      justify-content: center;
    }
    .app-hero-preview {
      min-height: auto;
      overflow: hidden;
      padding: 12px 0 28px;
    }
    .app-hero-preview::before {
      inset: 72px 8px 0;
      border-radius: 32px;
    }
    .hero-device {
      flex: 0 0 min(70vw, 270px);
    }
    .hero-device-primary {
      transform: none;
    }
    .hero-device-secondary {
      display: none;
    }
    .gallery-section { padding: 80px 24px; }
    .gallery-grid-screenshots,
    .gallery-grid-placeholders {
      overflow-x: auto;
