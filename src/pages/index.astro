---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import AppStoreBadge from '../components/AppStoreBadge.astro';
import PlaceholderCard from '../components/PlaceholderCard.astro';
import { apps } from '../data/apps';

const sincefy = apps.find((a) => a.slug === 'sincefy')!;
const luxira = apps.find((a) => a.slug === 'luxira')!;
const sopora = apps.find((a) => a.slug === 'sopora')!;
const logfd = apps.find((a) => a.slug === 'logfd')!;
---

<BaseLayout
  title="Pretty Toolkit — Aesthetic Utility Apps for iPhone"
  description="Pretty Toolkit is a curated collection of premium iOS utility apps designed with intention. Everyday tools, unexpectedly beautiful. Download Sincefy, Luxira, and discover Sopora."
>
  <!-- ===== HERO ===== -->
  <section class="hero grain-overlay">
    <!-- Icon mosaic — inverted triangle, widest at top, tapering down -->
    <div class="icon-mosaic">
      <div class="mosaic-pyramid">
        <!-- Row 1: 12 tiles — widest, partially hidden behind header -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.8s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.4s; --bg: linear-gradient(135deg, #E8B4B8, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.6s; --bg: linear-gradient(135deg, #EEC8C4, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.08s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.2s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.03s; --fd: 4.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.11s; --fd: 5.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.9s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.15s; --fd: 5.3s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
        </div>
        <!-- Row 2: 10 tiles -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.08s; --fd: 4.4s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.3s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.7s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.7s; --bg: linear-gradient(135deg, #F5DCD0, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.2s; --bg: linear-gradient(135deg, #E8B2AE, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.9s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.2s; --bg: linear-gradient(135deg, #F2D0CD, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.8s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.18s; --fd: 5.5s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
        </div>
        <!-- Row 3: 6 tiles -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.06s; --fd: 5.6s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 5.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 4.4s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
        </div>
        <!-- Row 4: public app icons, centered. -->
        <div class="m-row m-row-center">
          <a class="m-t m-t-icon m-t-link" href="/luxira" aria-label="Open Luxira" style="--d: 0.08s; --fd: 5.6s;"><img src="/icons/luxira.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href="/sopora" aria-label="Open Sopora" style="--d: 0.12s; --fd: 4.7s;"><img src="/icons/sopora.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href="/sincefy" aria-label="Open Sincefy" style="--d: 0.16s; --fd: 5.3s;"><img src="/icons/sincefy.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href="/logfd" aria-label="Open logfd" style="--d: 0.2s; --fd: 4.9s;"><img src="/icons/logfd.png" alt="" width="96" height="96" /></a>
        </div>
      </div>
    </div>

    <div class="hero-content section-choreography visible">
      <h1 class="hero-headline choreo-headline">
        <em>Everyday apps, unexpectedly beautiful.</em>
      </h1>
      <p class="hero-subtitle choreo-subtitle">
        Your phone deserves better tools.
      </p>
      <div class="hero-actions choreo-content">
        <a href="#apps" class="btn-primary">Explore the apps</a>
        <p class="trust-row" aria-label="Pretty Toolkit trust signals">
          <span>No ads</span>
          <span>Offline-first</span>
          <span>Private by design</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ===== INTRO ===== -->
  <section class="intro-section">
    <div class="intro-inner reveal section-choreography">
      <h2 class="intro-heading choreo-headline">What is Pretty Toolkit?</h2>
      <p class="intro-body choreo-subtitle">
        Pretty Toolkit is a curated collection of premium utility apps for iPhone. We take the tools you reach for every day — scanners, countdowns, journals, organizers — and rebuild them from the ground up with care, clarity, and warmth.
      </p>
      <p class="intro-body choreo-content">
        Every app in the collection is built with the same philosophy: no ads, no clutter, offline-first functionality, and full accessibility support including VoiceOver and Dynamic Type. We believe utility apps deserve the same level of polish as the apps you show off to your friends.
      </p>
    </div>
  </section>

  <!-- ===== FEATURED: SINCEFY ===== -->
  <section class="spotlight-section" style={`--app-accent: ${sincefy.accentColor};`}>
    <div class="spotlight reveal section-choreography">
      <div class="spotlight-copy">
        <div class="spotlight-icon choreo-headline">
          <img
            class="app-icon-img"
            src={sincefy.icon}
            alt={`${sincefy.name} app icon`}
            width="88"
            height="88"
            loading="lazy"
          />
        </div>
        <h2 class="spotlight-name choreo-subtitle">{sincefy.name}</h2>
        <p class="spotlight-tagline choreo-content">{sincefy.tagline}</p>
        <p class="spotlight-description choreo-meta">{sincefy.description}</p>
        <p class="spotlight-features choreo-cta-text">
          Home screen, lock screen, and StandBy countdowns for the moments you want to keep close.
        </p>
        <div class="spotlight-cta choreo-cta">
          {sincefy.status === 'live' && sincefy.appStoreUrl ? (
            <AppStoreBadge href={sincefy.appStoreUrl} />
          ) : (
            <span class="coming-soon-badge">Coming Soon</span>
          )}
          <p class="trust-row trust-row-compact" aria-label="Sincefy trust signals">
            <span>No ads</span>
            <span>Offline-first</span>
            <span>Private by design</span>
          </p>
        </div>
      </div>
      <div class="spotlight-preview choreo-content" aria-hidden="true">
        <picture>
          <source srcset={sincefy.screenshots[0].replace(/\.(png|jpe?g)$/i, '.webp')} type="image/webp" />
          <img src={sincefy.screenshots[0]} alt="" width="260" height="520" loading="lazy" />
        </picture>
      </div>
    </div>
  </section>

  <!-- ===== APP GRID ===== -->
  <section class="apps-section" id="apps">
    <div class="apps-section-inner">
      <h2 class="section-heading reveal-headline">Our Collection</h2>
      <div class="app-grid reveal-stagger">
        <AppCard app={sincefy} />
        <AppCard app={luxira} />
        <AppCard app={sopora} />
        <AppCard app={logfd} />
        <PlaceholderCard index={1} />
      </div>
    </div>
  </section>

  <!-- ===== BRAND STATEMENT ===== -->
  <section class="brand-story-section">
    <div class="brand-story reveal section-choreography">
      <h2 class="brand-story-heading choreo-headline">
        Everyday tools deserve extraordinary design.
      </h2>
      <div class="brand-story-body choreo-subtitle">
        <p>Every app in our collection is crafted with intention — because the details matter. The rounded corners, the haptic feedback, the way a screen transitions. These are the things that turn a utility into something you actually enjoy using.</p>
        <p>We sweat the small stuff so you don't have to think about it. You just open the app, do what you came to do, and move on — with a little more joy than you expected.</p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE CARE ABOUT ===== -->
  <section class="values-section">
    <div class="values-inner">
      <div class="value-item reveal">
        <h3 class="value-title">Privacy by default</h3>
        <p class="value-desc">Your data stays on your device. No ads, no accounts, no cross-app tracking. When an app uses anonymous diagnostics or analytics, it is disclosed clearly and never includes your personal content.</p>
      </div>
      <div class="value-item reveal">
        <h3 class="value-title">Accessible to everyone</h3>
        <p class="value-desc">Full VoiceOver support, Dynamic Type, and haptic feedback in every app. Great design means everyone can use it, regardless of how they interact with their iPhone.</p>
      </div>
      <div class="value-item reveal">
        <h3 class="value-title">No ads. Ever.</h3>
        <p class="value-desc">We don't sell your attention. Our apps are supported by optional premium upgrades — not by advertising, data sales, or dark patterns.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- WebSite Schema for sitelinks -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Pretty Toolkit",
  "url": "https://prettytoolkit.com",
  "description": "A curated collection of premium iOS utility apps designed with intention."
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Pretty Toolkit app collection",
  "itemListElement": apps.map((app, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": app.name,
    "url": `https://prettytoolkit.com/${app.slug}/`
  }))
})} />

<style>
  /* ===== HERO ===== */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px 80px;
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    max-width: 800px;
  }

  /* ===== ICON MOSAIC ===== */
  .icon-mosaic {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: -30px;
    margin-bottom: 60px;
  }
  .mosaic-pyramid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .m-row {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .m-row:nth-child(even) {
    transform: translateX(56px);
  }
  .m-row-center {
    transform: none !important;
  }
  .m-t {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    flex-shrink: 0;
    background: var(--bg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(-50px) scale(0.6);
    animation:
      m-drop 0.8s var(--ease-decelerate) var(--d) forwards,
      m-float var(--fd) var(--ease-standard) calc(var(--d) + 0.8s) infinite alternate;
  }
  .m-t-icon {
    background: none;
    overflow: hidden;
  }
  .m-t-link {
    color: inherit;
    text-decoration: none;
    transition: box-shadow var(--duration-fast) var(--ease-standard);
  }
  .m-t-link:hover,
  .m-t-link:focus-visible {
    box-shadow: var(--shadow-lg);
  }
  .m-t-link:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
  }
  .m-t-icon img {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: inherit;
  }

  @keyframes m-drop {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes m-float {
    from { transform: translateY(0); }
    to { transform: translateY(-5px); }
  }
  .hero-headline {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text-primary);
  }
  .hero-headline em {
    font-style: italic;
  }
  .hero-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .hero-actions {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .trust-row span {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .trust-row span:not(:last-child)::after {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--text-accent);
    opacity: 0.55;
  }
  /* ===== INTRO ===== */
  .intro-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .intro-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .intro-heading {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: 24px;
  }
  .intro-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  /* ===== SPOTLIGHT ===== */
  .spotlight-section {
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .spotlight {
    max-width: 1040px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(240px, 0.75fr);
    align-items: center;
    gap: 64px;
  }
  .spotlight-copy { text-align: left; }
  .spotlight-icon {
    margin-bottom: 24px;
  }
  .app-icon-img {
    width: 88px;
    height: 88px;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    display: inline-block;
  }
  .spotlight-name {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .spotlight-tagline {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-accent);
    margin-bottom: 20px;
  }
  .spotlight-description {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 0 16px;
  }
  .spotlight-features {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 0 28px;
    opacity: 0.85;
  }
  .spotlight-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .trust-row-compact {
    justify-content: flex-start;
    font-size: 0.75rem;
  }
  .spotlight-preview {
    position: relative;
    justify-self: center;
    padding: 20px;
    border-radius: 36px;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--app-accent) 14%, transparent),
        color-mix(in srgb, var(--warm-cream) 32%, transparent)
      );
    box-shadow: var(--shadow-sm);
  }
  .spotlight-preview::before {
    content: '';
    position: absolute;
    inset: 16px;
    border-radius: 32px;
    background: var(--card-bg);
    box-shadow: var(--shadow-lg);
  }
  .spotlight-preview picture,
  .spotlight-preview img {
    position: relative;
    display: block;
  }
  .spotlight-preview img {
    width: clamp(210px, 24vw, 280px);
    height: auto;
    border-radius: 28px;
  }
  .coming-soon-badge {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: rgba(232, 180, 184, 0.15);
    padding: 8px 24px;
    border-radius: 20px;
  }

  /* ===== APP GRID ===== */
  .apps-section {
    padding: 120px 0;
    background: var(--off-white);
  }
  .apps-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 768px) {
    .app-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  /* ===== BRAND STATEMENT ===== */
  .brand-story-section {
    background: var(--section-warm);
    padding: 120px 24px;
  }
  .brand-story {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-story-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 24px;
  }
  .brand-story-body p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .values-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .value-item {
    text-align: center;
  }
  .value-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .value-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero {
      padding-bottom: 56px;
    }
    .icon-mosaic {
      margin-top: -20px;
      margin-bottom: 32px;
    }
    .mosaic-pyramid { gap: 8px; }
    .m-row { gap: 8px; }
    .m-row:nth-child(even) { transform: translateX(32px); }
    .m-t { width: 48px; height: 48px; border-radius: 12px; }
    .hero-actions { margin-top: 24px; }
    .intro-section { padding: 80px 24px; }
    .spotlight-section { padding: 80px 24px; }
    .spotlight {
      grid-template-columns: 1fr;
      gap: 44px;
      text-align: center;
    }
    .spotlight-copy { text-align: center; }
    .spotlight-description,
    .spotlight-features {
      margin-left: auto;
      margin-right: auto;
    }
    .spotlight-cta {
      align-items: center;
    }
    .trust-row-compact {
      justify-content: center;
    }
    .spotlight-preview {
      padding: 16px;
    }
    .spotlight-preview img {
      width: min(72vw, 260px);
    }
    .apps-section { padding: 80px 0; }
    .brand-story-section { padding: 80px 24px; }
    .values-section { padding: 80px 24px; }
    .values-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
