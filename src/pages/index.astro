---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import PlaceholderCard from '../components/PlaceholderCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { apps } from '../data/apps';

const luxira = apps[0];
---

<BaseLayout
  title="Pretty Toolkit — Aesthetic Utility Apps for iPhone"
  description="Pretty Toolkit is a curated collection of premium iOS utility apps designed with intention. Everyday tools, unexpectedly beautiful. Download Luxira and more."
>
  <!-- ===== HERO ===== -->
  <section class="hero grain-overlay">
    <!-- Icon mosaic — inverted triangle, widest at top, tapering down -->
    <div class="icon-mosaic" aria-hidden="true">
      <div class="mosaic-pyramid">
        <!-- Row 1: 12 tiles — widest, partially hidden behind header -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.8s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.4s; --bg: linear-gradient(135deg, #E8B4B8, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.6s; --bg: linear-gradient(135deg, #EEC8C4, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.08s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.2s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.03s; --fd: 4.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.11s; --fd: 5.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.9s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.15s; --fd: 5.3s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
        </div>
        <!-- Row 2: 10 tiles -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.08s; --fd: 4.4s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.3s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.7s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.7s; --bg: linear-gradient(135deg, #F5DCD0, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.2s; --bg: linear-gradient(135deg, #E8B2AE, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.9s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.2s; --bg: linear-gradient(135deg, #F2D0CD, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.8s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.18s; --fd: 5.5s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
        </div>
        <!-- Row 3: 6 tiles -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.06s; --fd: 5.6s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 5.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 4.4s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
        </div>
        <!-- Row 4: 4 tiles — bottom point -->
        <div class="m-row">
          <div class="m-t" style="--d: 0.08s; --fd: 5.6s; --bg: linear-gradient(135deg, #E8B2AE, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 4.7s; --bg: linear-gradient(135deg, #F5DCD0, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.3s; --bg: linear-gradient(135deg, #E8B4B8, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.9s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
        </div>
      </div>
    </div>

    <div class="hero-content section-choreography visible">
      <h1 class="hero-headline choreo-headline">
        <em>Everyday apps, unexpectedly beautiful.</em>
      </h1>
      <p class="hero-subtitle choreo-subtitle">
        Your phone deserves better tools.
      </p>
    </div>
  </section>

  <!-- ===== INTRO ===== -->
  <section class="intro-section">
    <div class="intro-inner reveal section-choreography">
      <h2 class="intro-heading choreo-headline">Premium iOS utility apps, designed with intention.</h2>
      <p class="intro-body choreo-subtitle">
        Pretty Toolkit is a curated collection of utility apps for iPhone. We take the tools you reach for every day — scanners, converters, organizers — and rebuild them from the ground up with care, clarity, and warmth. No ads, no clutter, no data harvesting. Just beautifully crafted apps that respect your time and your privacy.
      </p>
      <p class="intro-body choreo-content">
        Every app in the collection is built with the same philosophy: thoughtful design, offline-first functionality, and full accessibility support including VoiceOver and Dynamic Type. We believe utility apps deserve the same level of polish as the apps you show off to your friends.
      </p>
    </div>
  </section>

  <!-- ===== FEATURED: LUXIRA ===== -->
  <section class="spotlight-section">
    <div class="spotlight reveal section-choreography">
      <div class="spotlight-icon choreo-headline">
        <div
          class="app-icon-placeholder"
          style={`background: ${luxira.accentColor};`}
        >
          <span>{luxira.name.charAt(0)}</span>
        </div>
      </div>
      <h2 class="spotlight-name choreo-subtitle">{luxira.name}</h2>
      <p class="spotlight-tagline choreo-content">{luxira.tagline}</p>
      <p class="spotlight-description choreo-meta">{luxira.description}</p>
      <p class="spotlight-features choreo-cta-text">
        Instant QR and barcode scanning. Custom QR code creation with style templates and logo badges. Scan history, favorites, and gallery scanning — all processed on-device, fully offline, with zero tracking.
      </p>
      <div class="choreo-cta">
        {luxira.status === 'live' && luxira.appStoreUrl ? (
          <a href={luxira.appStoreUrl} class="btn-primary" target="_blank" rel="noopener">
            Download on the App Store
          </a>
        ) : (
          <span class="coming-soon-badge">Coming Soon</span>
        )}
      </div>
    </div>
  </section>

  <!-- ===== APP GRID ===== -->
  <section class="apps-section" id="apps">
    <div class="apps-section-inner">
      <h2 class="section-heading reveal-headline">Our Collection</h2>
      <div class="app-grid reveal-stagger">
        <AppCard app={luxira} />
        <PlaceholderCard index={0} />
        <PlaceholderCard index={1} />
        <PlaceholderCard index={2} />
      </div>
    </div>
  </section>

  <!-- ===== BRAND STATEMENT ===== -->
  <section class="brand-story-section">
    <div class="brand-story reveal section-choreography">
      <h2 class="brand-story-heading choreo-headline">
        Everyday tools deserve extraordinary design.
      </h2>
      <div class="brand-story-body choreo-subtitle">
        <p>Every app in our collection is crafted with intention — because the details matter. The rounded corners, the haptic feedback, the way a screen transitions. These are the things that turn a utility into something you actually enjoy using.</p>
        <p>We sweat the small stuff so you don't have to think about it. You just open the app, do what you came to do, and move on — with a little more joy than you expected.</p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE CARE ABOUT ===== -->
  <section class="values-section">
    <div class="values-inner">
      <div class="value-item reveal">
        <h3 class="value-title">Privacy by default</h3>
        <p class="value-desc">Your data stays on your device. No tracking, no analytics SDKs, no accounts required. Every Pretty Toolkit app is built offline-first and verified through Apple's Privacy Manifests.</p>
      </div>
      <div class="value-item reveal">
        <h3 class="value-title">Accessible to everyone</h3>
        <p class="value-desc">Full VoiceOver support, Dynamic Type, and haptic feedback in every app. Great design means everyone can use it, regardless of how they interact with their iPhone.</p>
      </div>
      <div class="value-item reveal">
        <h3 class="value-title">No ads. Ever.</h3>
        <p class="value-desc">We don't sell your attention. Our apps are supported by optional premium upgrades — not by advertising, data sales, or dark patterns.</p>
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL CTA ===== -->
  <section class="social-cta-section reveal section-choreography">
    <h2 class="social-heading choreo-headline">Follow the journey</h2>
    <p class="social-subtitle choreo-subtitle">New apps, behind the scenes, and pretty things.</p>
    <div class="social-icons choreo-content">
      <SocialLinks size="md" />
    </div>
  </section>
</BaseLayout>

<!-- WebSite Schema for sitelinks -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Pretty Toolkit",
  "url": "https://prettytoolkit.com",
  "description": "A curated collection of premium iOS utility apps designed with intention."
})} />

<style>
  /* ===== HERO ===== */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px 80px;
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    max-width: 800px;
  }

  /* ===== ICON MOSAIC ===== */
  .icon-mosaic {
    width: 100%;
    display: flex;
    justify-content: center;
    pointer-events: none;
    margin-top: -30px;
    margin-bottom: 60px;
  }
  .mosaic-pyramid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .m-row {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .m-row:nth-child(even) {
    transform: translateX(56px);
  }
  .m-t {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    flex-shrink: 0;
    background: var(--bg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(-50px) scale(0.6);
    animation:
      m-drop 0.8s var(--ease-decelerate) var(--d) forwards,
      m-float var(--fd) var(--ease-standard) calc(var(--d) + 0.8s) infinite alternate;
  }

  @keyframes m-drop {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes m-float {
    from { transform: translateY(0); }
    to { transform: translateY(-5px); }
  }
  .hero-headline {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text-primary);
  }
  .hero-headline em {
    font-style: italic;
  }
  .hero-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  /* ===== INTRO ===== */
  .intro-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .intro-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .intro-heading {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: 24px;
  }
  .intro-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  /* ===== SPOTLIGHT ===== */
  .spotlight-section {
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .spotlight {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .spotlight-icon {
    margin-bottom: 24px;
  }
  .app-icon-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .app-icon-placeholder span {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 2rem;
    color: white;
  }
  .spotlight-name {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .spotlight-tagline {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-accent);
    margin-bottom: 20px;
  }
  .spotlight-description {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 16px;
  }
  .spotlight-features {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 32px;
    opacity: 0.85;
  }
  .coming-soon-badge {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: rgba(232, 180, 184, 0.15);
    padding: 8px 24px;
    border-radius: 20px;
  }

  /* ===== APP GRID ===== */
  .apps-section {
    padding: 120px 0;
    background: var(--off-white);
  }
  .apps-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 768px) {
    .app-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  /* ===== BRAND STATEMENT ===== */
  .brand-story-section {
    background: var(--section-warm);
    padding: 120px 24px;
  }
  .brand-story {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-story-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 24px;
  }
  .brand-story-body p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-section {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .values-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .value-item {
    text-align: center;
  }
  .value-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .value-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== SOCIAL CTA ===== */
  .social-cta-section {
    text-align: center;
    padding: 120px 24px;
    background: var(--off-white);
  }
  .social-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 12px;
  }
  .social-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .social-icons {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding-bottom: 60px;
    }
    .icon-mosaic {
      margin-top: -20px;
      margin-bottom: 40px;
    }
    .mosaic-pyramid { gap: 8px; }
    .m-row { gap: 8px; }
    .m-row:nth-child(even) { transform: translateX(32px); }
    .m-t { width: 48px; height: 48px; border-radius: 12px; }
    .intro-section { padding: 80px 24px; }
    .spotlight-section { padding: 80px 24px; }
    .apps-section { padding: 80px 0; }
    .brand-story-section { padding: 80px 24px; }
    .values-section { padding: 80px 24px; }
    .values-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .social-cta-section { padding: 80px 24px; }
  }
</style>
