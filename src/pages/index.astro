---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import PlaceholderCard from '../components/PlaceholderCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { apps } from '../data/apps';

const luxira = apps[0];
---

<BaseLayout
  title="Pretty Toolkit — Aesthetic Utility Apps for iPhone"
  description="Pretty Toolkit is a curated collection of premium iOS utility apps designed with intention. Everyday tools, unexpectedly beautiful. Download Luxira and more."
>
  <!-- ===== HERO ===== -->
  <section class="hero grain-overlay">
    <div class="hero-content section-choreography visible">
      <h1 class="hero-headline choreo-headline">
        <em>Everyday apps, unexpectedly beautiful.</em>
      </h1>
      <p class="hero-subtitle choreo-subtitle">
        Your phone deserves better tools.
      </p>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  <!-- ===== FEATURED: LUXIRA ===== -->
  <section class="spotlight-section">
    <div class="spotlight reveal section-choreography">
      <div class="spotlight-icon choreo-headline">
        <div
          class="app-icon-placeholder"
          style={`background: ${luxira.accentColor};`}
        >
          <span>{luxira.name.charAt(0)}</span>
        </div>
      </div>
      <h2 class="spotlight-name choreo-subtitle">{luxira.name}</h2>
      <p class="spotlight-tagline choreo-content">{luxira.tagline}</p>
      <p class="spotlight-description choreo-meta">{luxira.description}</p>
      <div class="choreo-cta">
        {luxira.status === 'live' && luxira.appStoreUrl ? (
          <a href={luxira.appStoreUrl} class="btn-primary" target="_blank" rel="noopener">
            Download on the App Store
          </a>
        ) : (
          <span class="coming-soon-badge">Coming Soon</span>
        )}
      </div>
    </div>
  </section>

  <!-- ===== APP GRID ===== -->
  <section class="apps-section" id="apps">
    <div class="apps-section-inner">
      <h2 class="section-heading reveal-headline">Our Collection</h2>
      <div class="app-grid reveal-stagger">
        <AppCard app={luxira} />
        <PlaceholderCard index={0} />
        <PlaceholderCard index={1} />
        <PlaceholderCard index={2} />
      </div>
    </div>
  </section>

  <!-- ===== BRAND STATEMENT ===== -->
  <section class="brand-story-section">
    <div class="brand-story reveal section-choreography">
      <h2 class="brand-story-heading choreo-headline">
        Everyday tools deserve extraordinary design.
      </h2>
      <div class="brand-story-body choreo-subtitle">
        <p>Every app in our collection is crafted with intention — because the details matter.</p>
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL CTA ===== -->
  <section class="social-cta-section reveal section-choreography">
    <h2 class="social-heading choreo-headline">Follow the journey</h2>
    <p class="social-subtitle choreo-subtitle">New apps, behind the scenes, and pretty things.</p>
    <div class="social-icons choreo-content">
      <SocialLinks size="md" />
    </div>
  </section>
</BaseLayout>

<!-- WebSite Schema for sitelinks -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Pretty Toolkit",
  "url": "https://prettytoolkit.com",
  "description": "A curated collection of premium iOS utility apps designed with intention."
})} />

<style>
  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 24px;
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    max-width: 800px;
  }
  .hero-headline {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text-primary);
  }
  .hero-headline em {
    font-style: italic;
  }
  .hero-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-tertiary);
    animation: pulse-down 2s var(--ease-standard) infinite;
  }

  /* ===== SPOTLIGHT ===== */
  .spotlight-section {
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .spotlight {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .spotlight-icon {
    margin-bottom: 24px;
  }
  .app-icon-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .app-icon-placeholder span {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 2rem;
    color: white;
  }
  .spotlight-name {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .spotlight-tagline {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-accent);
    margin-bottom: 20px;
  }
  .spotlight-description {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 32px;
  }
  .coming-soon-badge {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: rgba(232, 180, 184, 0.15);
    padding: 8px 24px;
    border-radius: 20px;
  }

  /* ===== APP GRID ===== */
  .apps-section {
    padding: 120px 0;
    background: var(--off-white);
  }
  .apps-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 768px) {
    .app-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  /* ===== BRAND STATEMENT ===== */
  .brand-story-section {
    background: var(--section-warm);
    padding: 120px 24px;
  }
  .brand-story {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-story-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 24px;
  }
  .brand-story-body p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== SOCIAL CTA ===== */
  .social-cta-section {
    text-align: center;
    padding: 120px 24px;
    background: var(--off-white);
  }
  .social-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 12px;
  }
  .social-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .social-icons {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .spotlight-section { padding: 80px 24px; }
    .apps-section { padding: 80px 0; }
    .brand-story-section { padding: 80px 24px; }
    .social-cta-section { padding: 80px 24px; }
  }
</style>
