---
import AppPage from '../../[slug]/index.astro';
import { apps } from '../../../data/apps';
import { locales, type Locale } from '../../../i18n';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  locales
    .filter((locale) => locale !== 'en')
    .flatMap((locale) =>
      apps.map((app) => ({
        params: { locale, slug: app.slug },
        props: { app, locale },
      }))
    );

const { app, locale } = Astro.props as { app: (typeof apps)[number]; locale: Locale };
---

<AppPage app={app} locale={locale} />
