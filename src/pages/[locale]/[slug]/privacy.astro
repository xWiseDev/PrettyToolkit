---
import AppPrivacyPage from '../../[slug]/privacy.astro';
import { apps } from '../../../data/apps';
import { locales, type Locale } from '../../../i18n';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  locales
    .filter((locale) => locale !== 'en')
    .flatMap((locale) =>
      apps
        .filter((app) => app.privacy)
        .map((app) => ({
          params: { locale, slug: app.slug },
          props: { app, locale },
        }))
    );

const { app, locale } = Astro.props as { app: (typeof apps)[number]; locale: Locale };
---

<AppPrivacyPage app={app} locale={locale} />
