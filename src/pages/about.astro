---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  defaultLocale,
  getLocalizedApps,
  localizedAlternates,
  localizedAppPath,
  localizedPath,
  type Locale,
  ui,
} from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const copy = ui[locale];
const localizedApps = getLocalizedApps(locale);
const canonicalPath = localizedPath(locale, '/about');
const alternatePaths = localizedAlternates('/about');
---

<BaseLayout
  title={copy.about.title}
  description={copy.about.description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
>
  <section class="about-hero grain-overlay">
    <!-- Icon mosaic — same inverted triangle as homepage -->
    <div class="icon-mosaic">
      <div class="mosaic-pyramid">
        <div class="m-row">
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.8s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.4s; --bg: linear-gradient(135deg, #E8B4B8, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.6s; --bg: linear-gradient(135deg, #EEC8C4, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.08s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.2s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.03s; --fd: 4.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.11s; --fd: 5.5s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.9s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.15s; --fd: 5.3s; --bg: linear-gradient(135deg, #EEC8C4, #E8B2AE);"></div>
        </div>
        <div class="m-row">
          <div class="m-t" style="--d: 0.08s; --fd: 4.4s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 5.3s; --bg: linear-gradient(135deg, #E8B4B8, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 4.7s; --bg: linear-gradient(135deg, #F2D0CD, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 5.7s; --bg: linear-gradient(135deg, #F5DCD0, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.06s; --fd: 4.2s; --bg: linear-gradient(135deg, #E8B2AE, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 5.9s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 4.5s; --bg: linear-gradient(135deg, #E8B4B8, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.12s; --fd: 5.2s; --bg: linear-gradient(135deg, #F2D0CD, #EEC8C4);"></div>
          <div class="m-t" style="--d: 0.07s; --fd: 4.8s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.18s; --fd: 5.5s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
        </div>
        <div class="m-row">
          <div class="m-t" style="--d: 0.06s; --fd: 5.6s; --bg: linear-gradient(135deg, #E8B4B8, #E8B2AE);"></div>
          <div class="m-t" style="--d: 0.14s; --fd: 4.3s; --bg: linear-gradient(135deg, #F5DCD0, #F2D0CD);"></div>
          <div class="m-t" style="--d: 0.04s; --fd: 5.4s; --bg: linear-gradient(135deg, #F2D0CD, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.1s; --fd: 4.6s; --bg: linear-gradient(135deg, #E8B2AE, #F5DCD0);"></div>
          <div class="m-t" style="--d: 0.02s; --fd: 5.8s; --bg: linear-gradient(135deg, #EEC8C4, #E8B4B8);"></div>
          <div class="m-t" style="--d: 0.16s; --fd: 4.4s; --bg: linear-gradient(135deg, #F5DCD0, #EEC8C4);"></div>
        </div>
        <div class="m-row m-row-center">
          <a class="m-t m-t-icon m-t-link" href={localizedAppPath(locale, 'luxira')} aria-label="Open Luxira" style="--d: 0.08s; --fd: 5.6s;"><img src="/icons/luxira.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href={localizedAppPath(locale, 'sopora')} aria-label="Open Sopora" style="--d: 0.12s; --fd: 4.7s;"><img src="/icons/sopora.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href={localizedAppPath(locale, 'sincefy')} aria-label="Open Sincefy" style="--d: 0.16s; --fd: 5.3s;"><img src="/icons/sincefy.png" alt="" width="96" height="96" /></a>
          <a class="m-t m-t-icon m-t-link" href={localizedAppPath(locale, 'logfd')} aria-label="Open logfd" style="--d: 0.2s; --fd: 4.9s;"><img src="/icons/logfd.png" alt="" width="96" height="96" /></a>
        </div>
      </div>
    </div>

    <div class="about-content section-choreography visible">
      <h1 class="about-headline choreo-headline">
        <em>{copy.about.heading}</em>
      </h1>
    </div>
  </section>

  <section class="about-story">
    <div class="story-inner reveal section-choreography">
      <p class="story-text choreo-headline">
        {copy.about.story}
      </p>
      <p class="story-body choreo-subtitle">
        {copy.about.body1}
      </p>
      <p class="story-body choreo-content">
        {copy.about.body2}
      </p>
    </div>
  </section>

  <section class="about-approach">
    <div class="approach-inner reveal section-choreography">
      <h2 class="approach-heading choreo-headline">{copy.about.approachHeading}</h2>
      <p class="approach-body choreo-subtitle">
        {copy.about.approach1}
      </p>
      <p class="approach-body choreo-content">
        {copy.about.approach2}
      </p>
    </div>
  </section>

  <section class="about-principles">
    <div class="principles-inner">
      {copy.about.principles.map(([title, desc]) => (
        <div class="principle reveal">
          <h2 class="principle-title">{title}</h2>
          <p class="principle-desc">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="about-apps">
    <div class="about-apps-inner reveal section-choreography">
      <h2 class="about-apps-heading choreo-headline">{copy.about.appsHeading}</h2>
      <p class="about-apps-body choreo-subtitle">
        {copy.about.appsIntro}
      </p>
      {localizedApps.filter((app) => app.status === 'live').map((app) => (
        <p class="about-apps-body choreo-content">
          <a href={localizedAppPath(locale, app.slug)}>{app.name}</a>: {app.description}
        </p>
      ))}
      <p class="about-apps-body choreo-meta">
        {copy.about.more}
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px 80px;
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
  }
  .about-headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--text-primary);
  }

  /* ===== ICON MOSAIC ===== */
  .icon-mosaic {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: -30px;
    margin-bottom: 60px;
  }
  .mosaic-pyramid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .m-row {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .m-row:nth-child(even) {
    transform: translateX(56px);
  }
  .m-row-center {
    transform: none !important;
  }
  .m-t {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    flex-shrink: 0;
    background: var(--bg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(-50px) scale(0.6);
    animation:
      m-drop 0.8s var(--ease-decelerate) var(--d) forwards,
      m-float var(--fd) var(--ease-standard) calc(var(--d) + 0.8s) infinite alternate;
  }
  .m-t-icon {
    background: none;
    overflow: hidden;
  }
  .m-t-link {
    color: inherit;
    text-decoration: none;
    transition: box-shadow var(--duration-fast) var(--ease-standard);
  }
  .m-t-link:hover,
  .m-t-link:focus-visible {
    box-shadow: var(--shadow-lg);
  }
  .m-t-link:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
  }
  .m-t-icon img {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: inherit;
  }
  @keyframes m-drop {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes m-float {
    from { transform: translateY(0); }
    to { transform: translateY(-5px); }
  }

  .about-story {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .story-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .story-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 24px;
  }
  .story-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .about-approach {
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .approach-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .approach-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 24px;
  }
  .approach-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .about-principles {
    padding: 120px 24px;
    background: var(--off-white);
  }
  .principles-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .principle {
    text-align: center;
  }
  .principle-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .principle-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .about-apps {
    padding: 120px 24px;
    background: var(--section-warm);
  }
  .about-apps-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .about-apps-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 24px;
  }
  .about-apps-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .about-apps-body a {
    color: var(--text-accent);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .about-apps-body a:hover {
    color: var(--deeper-rose);
  }

  .about-social {
    text-align: center;
    padding: 120px 24px;
    background: var(--off-white);
  }
  .social-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 12px;
  }
  .social-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .social-icons {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .about-hero { padding: 0 24px 60px; }
    .icon-mosaic { margin-top: -20px; margin-bottom: 40px; }
    .mosaic-pyramid { gap: 8px; }
    .m-row { gap: 8px; }
    .m-row:nth-child(even) { transform: translateX(32px); }
    .m-t { width: 48px; height: 48px; border-radius: 12px; }
    .about-story { padding: 80px 24px; }
    .about-approach { padding: 80px 24px; }
    .about-principles { padding: 80px 24px; }
    .principles-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-apps { padding: 80px 24px; }
    .about-social { padding: 80px 24px; }
  }
</style>
