---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import {
  defaultLocale,
  getSupportFaqs,
  localizedAlternates,
  localizedPath,
  type Locale,
  ui,
} from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const copy = ui[locale];
const generalFaqs = getSupportFaqs(locale);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://prettytoolkit.com';
const canonicalPath = localizedPath(locale, '/support');
const alternatePaths = localizedAlternates('/support');
const supportUrl = new URL(canonicalPath, siteUrl).toString();
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": copy.support.title,
  "description": copy.support.schemaDescription,
  "url": supportUrl,
  "inLanguage": locale,
  "mainEntity": {
    "@type": "Organization",
    "name": "Pretty Toolkit",
    "url": siteUrl,
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "aboyahyadev@icloud.com",
      "contactType": copy.brand.supportContactType,
      "url": supportUrl,
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "inLanguage": locale,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Pretty Toolkit",
      "item": new URL(locale === 'en' ? '/' : `/${locale}/`, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": copy.nav.support,
      "item": supportUrl,
    },
  ],
};
---

<BaseLayout
  title={copy.support.title}
  description={copy.support.description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
>
  <article class="support-page">
    <h1 class="support-heading reveal-headline">{copy.support.heading}</h1>
    <p class="support-subtitle reveal">
      {copy.support.subtitle}
    </p>

    <!-- Contact -->
    <section class="support-contact reveal">
      <h2>{copy.support.contactHeading}</h2>
      <p>
        {copy.support.contactCopy}<br />
        <a href="mailto:aboyahyadev@icloud.com?subject=Pretty%20Toolkit%20Support" class="support-email">aboyahyadev@icloud.com</a>
      </p>
    </section>

    <!-- FAQ -->
    <section class="support-faq reveal">
      <h2>{copy.support.faqHeading}</h2>
      <FaqAccordion faqs={generalFaqs} />
    </section>
  </article>
</BaseLayout>

<style>
  .support-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 120px 24px 160px;
  }
  .support-heading {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 12px;
  }
  .support-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    margin-bottom: 64px;
    line-height: 1.7;
  }
  .support-contact,
  .support-faq {
    margin-bottom: 64px;
  }
  .support-contact h2,
  .support-faq h2 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .support-contact p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .support-email {
    color: var(--text-accent);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .support-email:hover {
    color: var(--deeper-rose);
  }

  @media (max-width: 768px) {
    .support-page { padding: 80px 24px 120px; }
  }
</style>

<!-- FAQ Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": locale,
  "mainEntity": generalFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />

<script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
