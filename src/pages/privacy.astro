---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  defaultLocale,
  getGeneralPrivacySections,
  getLocalizedApps,
  localizedAlternates,
  localizedPrivacyPath,
  type Locale,
  ui,
} from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const copy = ui[locale];
const localizedApps = getLocalizedApps(locale);
const appsWithPrivacy = localizedApps.filter((app) => app.privacy);
const sections = getGeneralPrivacySections(locale);
const canonicalPath = localizedPrivacyPath(locale);
const alternatePaths = localizedAlternates('/privacy');
---

<BaseLayout
  title={copy.privacy.title}
  description={copy.privacy.description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
>
  <article class="legal-page">
    <h1 class="legal-heading reveal-headline">{copy.privacy.heading}</h1>
    <p class="legal-updated">{copy.privacy.updated}</p>

    <div class="legal-content reveal">
      <p>
        {copy.privacy.intro}
      </p>

      {appsWithPrivacy.length > 0 && (
        <div class="app-policies">
          <h2>{copy.privacy.appPolicies}</h2>
          <ul>
            {appsWithPrivacy.map((app) => (
              <li>
                <a href={localizedPrivacyPath(locale, app.slug)}>{copy.privacy.appPolicyLabel(app.name)}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {sections.map((section) => (
        <>
          <h2>{section.heading}</h2>
          <Fragment set:html={section.content} />
        </>
      ))}
    </div>
  </article>
</BaseLayout>

<style>
  .legal-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 120px 24px 160px;
  }
  .legal-heading {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 8px;
  }
  .legal-updated {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-bottom: 48px;
  }
  .app-policies {
    background: var(--section-warm);
    border-radius: 16px;
    padding: 24px 32px;
    margin: 24px 0 32px;
  }
  .app-policies h2 {
    margin-top: 0 !important;
  }
  .app-policies ul {
    padding-left: 0;
    list-style: none;
  }
  .app-policies li {
    margin-bottom: 8px;
  }
  .app-policies a {
    font-weight: 500;
  }
  .legal-content h2 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .legal-content p,
  .legal-content li {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .legal-content ul {
    padding-left: 24px;
    margin-bottom: 12px;
  }
  .legal-content a {
    color: var(--text-accent);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .legal-content a:hover {
    color: var(--deeper-rose);
  }

  @media (max-width: 768px) {
    .legal-page { padding: 80px 24px 120px; }
  }
</style>
