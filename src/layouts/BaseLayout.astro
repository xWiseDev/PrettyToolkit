---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, locales, localizedAlternates, localizedPath, type Locale, ui } from '../i18n';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  canonicalPath?: string;
  locale?: Locale;
  alternatePaths?: Record<Locale, string>;
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  canonicalUrl,
  canonicalPath = Astro.url.pathname,
  locale = defaultLocale,
  alternatePaths = localizedAlternates(canonicalPath),
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://prettytoolkit.com';
const canonical = canonicalUrl || new URL(alternatePaths[locale] || canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const copy = ui[locale];
const alternateUrls = locales.map((alternateLocale) => ({
  locale: alternateLocale,
  href: new URL(alternatePaths[alternateLocale], siteUrl).toString(),
}));
const xDefaultUrl = new URL(alternatePaths[defaultLocale], siteUrl).toString();
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateUrls.map((alternate) => (
      <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pretty Toolkit" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Pretty Toolkit",
      "url": "https://prettytoolkit.com",
      "logo": new URL('/favicon.png', siteUrl).toString(),
      "description": copy.brand.organizationDescription,
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": copy.brand.supportContactType,
        "url": new URL(localizedPath(locale, '/support'), siteUrl).toString()
      },
      "sameAs": []
    })} />

    <!-- Font preloads -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/playfairdisplay/v37/nuFvD-vYSZviVYUb_rj3ij__anPXJzDwcbmjWBN2PKd3vXDXbtXK-F2qC0s.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/dmsans/v15/rP2tp2ywxg089UriI5-g4vlH9VoD8CmsAOKuiG-ovKSu.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <div class="scroll-progress"></div>
    <Header locale={locale} currentPath={canonicalPath} alternatePaths={alternatePaths} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} currentPath={canonicalPath} alternatePaths={alternatePaths} />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
      );

      document
        .querySelectorAll('.reveal, .reveal-headline, .reveal-stagger, .section-choreography')
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
